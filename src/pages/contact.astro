---
import MainLayout from '@/layouts/MainLayout.astro';
import ContactForm from '@/components/vue/ContactForm.vue';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://coachtechno.com';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'CoachTechno',
  url: siteUrl,
  description: "Consultant IA pour PME au Québec. Audit IA, formation et implantation d'automatisations.",
  founder: {
    '@type': 'Person',
    name: 'Jimmy Gilbert',
  },
  areaServed: { '@type': 'Place', name: 'Québec, Canada' },
  sameAs: ['https://linkedin.com/in/jimmygilbert'],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    availableLanguage: 'French',
  },
};
---

<MainLayout
  title="Contact"
  description="Réservez une consultation gratuite avec Jimmy Gilbert, consultant IA au Québec. Appel découverte de 30 minutes pour discuter de vos besoins en automatisation."
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-surface-900 text-white section-pad">
    <div class="container-site text-center">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4">Contactez-moi pour une consultation IA gratuite</h1>
      <p class="text-gray-400 text-lg max-w-xl mx-auto">
        Réservez un appel découverte gratuit de 30 minutes. Aucun engagement.
      </p>
    </div>
  </section>

  <!-- Options de contact -->
  <section class="section-pad">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-heading font-bold text-white mb-6">Envoyez-moi un message</h2>
          <ContactForm client:load />
        </div>

        <div class="space-y-8">
          <div>
            <h2 class="text-2xl font-heading font-bold text-white mb-6">Autres façons de me joindre</h2>
            <div class="space-y-4">
              <div class="card">
                <div class="flex items-center gap-4">
                  <span class="text-3xl">📅</span>
                  <div>
                    <p class="font-semibold text-white">Réserver directement</p>
                    <p class="text-sm text-gray-400 mb-2">Choisissez un créneau dans mon calendrier.</p>
                    <a
                      href="https://calendly.com/jimmygilbert"
                      target="_blank"
                      rel="noopener"
                      class="btn-primary text-sm"
                    >
                      Ouvrir Calendly
                    </a>
                  </div>
                </div>
              </div>

              <div class="card">
                <div class="flex items-center gap-4">
                  <span class="text-3xl">💼</span>
                  <div>
                    <p class="font-semibold text-white">LinkedIn</p>
                    <p class="text-sm text-gray-400 mb-2">Connectez-vous avec moi sur LinkedIn.</p>
                    <a
                      href="https://linkedin.com/in/jimmygilbert"
                      target="_blank"
                      rel="noopener"
                      class="btn-secondary text-sm"
                    >
                      Voir mon profil
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-surface-700 border border-surface-600 rounded-2xl p-6">
            <h3 class="font-heading font-bold text-white mb-4">Ce à quoi s'attendre</h3>
            <ul class="space-y-3">
              {[
                'Réponse dans les 24 heures',
                'Appel découverte gratuit de 30 min',
                'Aucune pression, aucun engagement',
                'Recommandations personnalisées à votre situation',
              ].map(item => (
                <li class="flex items-center gap-2 text-gray-300 text-sm">
                  <svg class="w-5 h-5 text-brand-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <p class="text-gray-500 text-sm mt-6">
            Consultez mes <a href="/services" class="text-brand-400 hover:text-brand-300">services IA pour PME</a>
            ou le <a href="/coaching-technologique" class="text-brand-400 hover:text-brand-300">coaching technologique</a> pour en savoir plus.
          </p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
