---
import MainLayout from '@/layouts/MainLayout.astro';

const packages = [
  {
    heures: 5,
    prix: '750 $',
    desc: 'Idéal pour démarrer et clarifier votre stratégie numérique.',
    populaire: false,
  },
  {
    heures: 10,
    prix: '1 400 $',
    desc: 'Le choix le plus populaire pour une transformation concrète.',
    populaire: true,
  },
  {
    heures: 20,
    prix: '2 600 $',
    desc: 'Pour un accompagnement complet sur plusieurs mois.',
    populaire: false,
  },
];
---

<MainLayout
  title="Coaching technologique"
  description="Coaching technologique personnalisé pour travailleurs autonomes, consultants et professionnels. Automatisation, outils numériques, stratégie IA."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-950 to-brand-800 text-white section-pad">
    <div class="container-site text-center">
      <p class="text-accent-400 font-semibold text-sm uppercase tracking-widest mb-4">Pour travailleurs autonomes et professionnels</p>
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4">
        Coaching technologique
      </h1>
      <p class="text-brand-200 text-lg max-w-2xl mx-auto">
        Un accompagnement personnalisé pour optimiser vos outils, automatiser votre travail et développer votre stratégie numérique.
      </p>
    </div>
  </section>

  <!-- Pour qui -->
  <section class="section-pad">
    <div class="container-site">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="section-title">Pour qui est ce service?</h2>
          <p class="text-gray-600 mb-6">
            Le coaching technologique est conçu pour les professionnels qui veulent aller plus vite, travailler plus intelligemment et exploiter la technologie à leur avantage.
          </p>
          <ul class="space-y-3">
            {[
              { icon: '💼', label: 'Travailleurs autonomes' },
              { icon: '🧑‍💼', label: 'Consultants' },
              { icon: '👩‍⚕️', label: 'Professionnels (comptables, courtiers, thérapeutes...)' },
              { icon: '🚀', label: 'Entrepreneurs en démarrage' },
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-700">
                <span class="text-2xl">{item.icon}</span>
                <span>{item.label}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-brand-50 rounded-3xl p-8">
          <h3 class="font-heading font-bold text-xl text-gray-900 mb-4">Ce qu'on travaille ensemble</h3>
          <ul class="space-y-3">
            {[
              'Automatisation de votre travail quotidien',
              'Optimisation de vos outils numériques',
              'Stratégie numérique personnalisée',
              'IA personnelle (ChatGPT, Notion AI, etc.)',
              'Productivité et organisation',
            ].map(item => (
              <li class="flex items-center gap-2 text-gray-700">
                <svg class="w-5 h-5 text-brand-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Modèle banque d'heures -->
  <section class="section-pad bg-gray-50">
    <div class="container-site">
      <div class="text-center mb-12">
        <h2 class="section-title">Modèle banque d'heures</h2>
        <p class="section-subtitle">
          Achetez un bloc d'heures et utilisez-les à votre rythme, selon vos besoins.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {packages.map(pkg => (
          <div class:list={[
            'card text-center relative',
            pkg.populaire ? 'border-brand-500 border-2 shadow-lg' : '',
          ]}>
            {pkg.populaire && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-brand-600 text-white text-xs font-semibold px-4 py-1 rounded-full">
                Plus populaire
              </span>
            )}
            <p class="text-5xl font-heading font-bold text-brand-700 mb-1">{pkg.heures}h</p>
            <p class="text-2xl font-semibold text-gray-900 mb-3">{pkg.prix}</p>
            <p class="text-gray-600 text-sm mb-6">{pkg.desc}</p>
            <a href={`/contact?service=coaching&heures=${pkg.heures}`} class:list={[
              'block text-center text-sm font-semibold py-3 px-6 rounded-xl transition-colors',
              pkg.populaire
                ? 'bg-brand-600 text-white hover:bg-brand-700'
                : 'border-2 border-brand-600 text-brand-700 hover:bg-brand-50',
            ]}>
              Choisir ce forfait
            </a>
          </div>
        ))}
      </div>
      <p class="text-center text-gray-500 text-sm mt-6">
        Les heures sont valides 6 mois. Sessions en ligne ou en personne (Québec).
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-pad bg-brand-950 text-white text-center">
    <div class="container-site max-w-2xl">
      <h2 class="text-3xl font-heading font-bold mb-4">Prêt à travailler plus intelligemment?</h2>
      <p class="text-brand-200 mb-8">
        Réservez un appel gratuit de 30 minutes pour discuter de vos objectifs.
      </p>
      <a href="/contact" class="btn-primary text-base px-10 py-4">Réserver un appel</a>
    </div>
  </section>
</MainLayout>
