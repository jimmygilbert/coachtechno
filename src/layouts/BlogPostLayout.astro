---
import MainLayout from './MainLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const formattedDate = pubDate.toLocaleDateString('fr-CA', { year: 'numeric', month: 'long', day: 'numeric' });
---

<MainLayout title={title} description={description}>
  <article class="container-site section-pad max-w-3xl">
    <!-- Header article -->
    <header class="mb-10">
      {tags && (
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.map((tag: string) => (
            <span class="text-xs font-medium bg-brand-50 text-brand-700 px-3 py-1 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      )}
      <h1 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 mb-4">{title}</h1>
      <p class="text-gray-500 text-sm">{formattedDate}</p>
    </header>

    <!-- Contenu -->
    <div class="prose prose-lg prose-brand max-w-none">
      <slot />
    </div>

    <!-- CTA fin d'article -->
    <div class="mt-16 bg-brand-50 rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-heading font-bold text-gray-900 mb-3">
        Prêt à automatiser votre entreprise?
      </h2>
      <p class="text-gray-600 mb-6">
        Réservez un appel découverte gratuit de 30 minutes.
      </p>
      <a href="/contact" class="btn-primary">Réserver une consultation</a>
    </div>
  </article>
</MainLayout>
