---
import MainLayout from './MainLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const formattedDate = pubDate.toLocaleDateString('fr-CA', { year: 'numeric', month: 'long', day: 'numeric' });

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://coachtechno.com';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Jimmy Gilbert',
    url: `${siteUrl}/a-propos`,
  },
  publisher: {
    '@type': 'Organization',
    name: 'CoachTechno',
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${siteUrl}/blog/${post.slug}`,
  },
  ...(tags?.length && { keywords: tags.join(', ') }),
};
---

<MainLayout title={title} description={description} schema={schema}>
  <article class="container-site section-pad max-w-3xl">
    <header class="mb-10">
      {tags && (
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.map((tag: string) => (
            <span class="text-xs font-medium bg-brand-500/15 text-brand-400 px-3 py-1 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      )}
      <h1 class="text-3xl md:text-4xl font-heading font-bold text-white mb-4">{title}</h1>
      <p class="text-gray-500 text-sm">{formattedDate}</p>
    </header>

    <div class="prose prose-lg prose-invert max-w-none prose-headings:text-white prose-a:text-brand-400 prose-strong:text-white prose-code:text-accent-400">
      <slot />
    </div>

    <div class="mt-16 bg-surface-700 border border-surface-600 rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-heading font-bold text-white mb-3">
        Prêt à automatiser votre entreprise?
      </h2>
      <p class="text-gray-400 mb-6">
        Réservez un appel découverte gratuit de 30 minutes.
      </p>
      <a href="/contact" class="btn-primary">Réserver une consultation</a>
    </div>
  </article>
</MainLayout>
